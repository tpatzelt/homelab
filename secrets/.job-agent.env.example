# Telegram job application agent (ghcr.io/tpatzelt/job-application-agent)
# Image is built by GitHub Actions in tpatzelt/job-application-agent.
BRAVE_API_KEY=your-brave-search-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
TELEGRAM_BOT_TOKEN=123456789:your-telegram-bot-token
# Optional: only used by the one-shot CLI notifier, not the bot service
# (the bot discovers each user's chat id itself).
TELEGRAM_CHAT_ID=
LOG_LEVEL=INFO
