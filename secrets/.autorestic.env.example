# Autorestic backup environment variables
# Copy to .autorestic.env and fill in values
# Sourced by autorestic/autorestic.sh (not a compose stack — no symlink needed)

# Password for the restic backup repository.
# Keep the single quotes: the file is source'd by bash, so an unquoted value
# containing ` $ ! etc. gets mangled by command substitution.
RESTIC_PASSWORD='your_restic_password'

# Same password, under the name autorestic reads for the backup-hdd backend.
# autorestic does NOT expand ${VARS} in the config's key field (it would use
# the literal string as the password), so the key must arrive via this env
# var. Unquoted var-to-var assignment is safe in bash — leave it as is.
AUTORESTIC_BACKUP_HDD_RESTIC_PASSWORD=$RESTIC_PASSWORD

# Healthchecks.io ping URL for backup monitoring (optional — pings are skipped
# if unset). Create a check at https://healthchecks.io (schedule: weekly,
# Wed ~03:00 UTC, grace ~6h) and paste its ping URL here.
HEALTHCHECKS_URL='https://hc-ping.com/your-check-uuid'
