# Autorestic backup environment variables
# Copy to .autorestic.env and fill in values
# Sourced by autorestic/autorestic.sh (not a compose stack — no symlink needed)

# Password for the restic backup repository.
# Keep the single quotes: the file is source'd by bash, so an unquoted value
# containing ` $ ! etc. gets mangled by command substitution.
RESTIC_PASSWORD='your_restic_password'
