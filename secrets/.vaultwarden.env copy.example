# Vaultwarden Password Manager Environment Variables
# Copy to .vaultwarden.env and fill in values

# Optional: Admin panel token (generate with: openssl rand -base64 48)
# Uncomment to enable admin panel at /admin
# VAULTWARDEN_ADMIN_TOKEN=your_admin_token

# Optional: SMTP settings for email notifications
# SMTP_HOST=smtp.your-email-provider.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=your_email@example.com
# SMTP_PASSWORD=your_email_password
# SMTP_FROM=vaultwarden@your-domain.com
