# Core Services Environment Variables
# Copy to .core.env and fill in values

# User/Group IDs for file permissions
PUID=1000
PGID=1000

# Pi-hole web interface password
PIHOLE_FTLCONF_webserver_api_password=your_secure_password

# Beszel monitoring agent configuration
# Get these from Beszel hub after initial setup
BESZEL_AGENT_KEY=your_beszel_agent_key
BESZEL_TOKEN=your_beszel_token
BESZEL_HUB_URL=https://beszel.your-domain.com
