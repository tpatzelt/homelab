# annabel-rene frontend environment variables
# Copy to .annabel-rene.env and fill in values

# HMAC secret for the signed session cookie. Generate: openssl rand -hex 32
# Rotating it logs everyone out.
ANNABEL_RENE_SESSION_SECRET=

# PocketBase superuser impersonation token, used server-side by the frontend
# to read site_config. Generate in the admin UI once the backend is running:
# Collections -> _superusers -> record -> Impersonate -> long duration.
ANNABEL_RENE_PB_ADMIN_TOKEN=

# Expected answer to the anti-bot question (compared trimmed, case-insensitive).
ANNABEL_RENE_BOT_ANSWER=
