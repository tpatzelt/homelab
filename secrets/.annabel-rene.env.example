# annabel-rene frontend environment variables
# Copy to .annabel-rene.env and fill in values

# HMAC secret for the signed session cookie (friends + admin). Generate: openssl rand -hex 32
# Rotating it logs everyone out, including admin.
ANNABEL_RENE_SESSION_SECRET=

# Password for /admin (delete archive entries, curate timeline, set friends
# password, set video link). Missing/empty disables the admin area entirely.
ANNABEL_RENE_ADMIN_PASSWORD=

# Public URL of the site (canonical links, OG tags)
ANNABEL_RENE_PUBLIC_SITE_URL=https://annabel-rene.example.com
