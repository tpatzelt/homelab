# Caddy Reverse Proxy Environment Variables
# Copy to .caddy.env and fill in values

# Cloudflare API token for DNS-01 ACME challenge
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Zone:DNS:Edit for your domain
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# CrowdSec bouncer API key for the Caddy CrowdSec module
# Generate on the crowdsec container: docker exec crowdsec cscli bouncers add caddy-bouncer
CROWDSEC_BOUNCER_API_KEY=your_crowdsec_bouncer_api_key

# Base domain for all Caddy host matchers ({$DOMAIN} in the Caddyfile)
# and the goaccess URLs in compose.yaml (${DOMAIN})
DOMAIN=example.com
