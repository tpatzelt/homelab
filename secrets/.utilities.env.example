# Utilities Stack Environment Variables
# Copy to .utilities.env and fill in values

# User/Group IDs and timezone (used by ip-tracker)
PUID=1000
PGID=1000
TZ=Europe/Berlin

# Karakeep bookmark manager
KARAKEEP_VERSION=release

# Meilisearch master key for Karakeep search
# Generate with: openssl rand -base64 32
MEILI_MASTER_KEY=your_meilisearch_master_key

# Optional: AI-powered features (uncomment and configure if using)
# OPENAI_BASE_URL=http://llama-cpp:8080/v1
# OPENAI_API_KEY=sk-dummy-key
# INFERENCE_TEXT_MODEL=your_model_name
