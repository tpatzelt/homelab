# *arr Stack Environment Variables
# Copy to .arr.env and fill in values

# User/Group IDs for file permissions (run `id` to find yours)
PUID=1000
PGID=1000

# VPN Configuration (AirVPN)
# Get your wireguard config from AirVPN client area
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key
WIREGUARD_ADDRESSES=10.x.x.x/32
