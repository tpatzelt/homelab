# Jellyfin Environment Variables Example
# Copy this to .jellyfin.env in this directory and edit values as needed

# User/Group IDs for file permissions
# PUID and PGID should match the user that owns your media files
PUID=1000
PGID=1000

# Timezone
TZ=Europe/Berlin

# Public URL (set to your Caddy domain) — used for generating public links
# Example: https://jellyfin.example.com
JELLYFIN_PublishedServerUrl=https://jellyfin.tim-boo.com

# Cache directory inside the container (compose mounts /opt/dockerdata/jellyfin/cache -> /cache)
JELLYFIN_CACHE_DIR=/cache

# Optional: enable hardware acceleration by mounting /dev/dri in compose and configuring Jellyfin
# Example: uncomment devices in compose and set transcoding options in Jellyfin UI
