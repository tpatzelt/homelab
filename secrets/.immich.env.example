# Immich Photo Server Environment Variables
# Copy to .immich.env and fill in values

# Immich version (leave as 'release' for latest stable)
IMMICH_VERSION=release

# Storage paths (use absolute paths)
IMMICH_UPLOAD_LOCATION=/mnt/storage/immich/upload
IMMICH_DB_DATA_LOCATION=/opt/dockerdata/immich/postgres

# PostgreSQL credentials
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=your_secure_db_password
IMMICH_DB_DATABASE_NAME=immich
