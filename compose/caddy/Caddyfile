{
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	geoip2 {
		db_path /etc/caddy/GeoLite2-City.mmdb
	}
}

*.dev.tim-boo.com {
	@beszel host beszel.dev.tim-boo.com
	handle @beszel {
		reverse_proxy beszel:8090
	}

	@dozzle host dozzle.dev.tim-boo.com
	handle @dozzle {
		reverse_proxy dozzle:8080
	}

	@pihole host pihole.dev.tim-boo.com
	handle @pihole {
		redir / /admin/
		reverse_proxy https://pihole:443 {
			transport http {
				tls_insecure_skip_verify
			}
		}
	}

	@heimdall host heimdall.dev.tim-boo.com
	handle @heimdall {
		reverse_proxy heimdall:80
	}

	@immich host immich.dev.tim-boo.com
	handle @immich {
		reverse_proxy immich-server:2283
	}

	@karakeep host karakeep.dev.tim-boo.com
	handle @karakeep {
		reverse_proxy karakeep:3000
	}

	@jellyfin host jellyfin.dev.tim-boo.com
	handle @jellyfin {
		reverse_proxy jellyfin:8096 {
		header_up X-Forwarded-Proto https
		}
	}

	@qb host qbittorrent.dev.tim-boo.com
	handle @qb {
		reverse_proxy gluetun:8081
	}

	@prowlarr host prowlarr.dev.tim-boo.com
	handle @prowlarr {
		reverse_proxy gluetun:9696
	}

	@seerr host seerr.dev.tim-boo.com
	handle @seerr {
		reverse_proxy seerr:5055
	}

	@sonarr host sonarr.dev.tim-boo.com
	handle @sonarr {
		reverse_proxy gluetun:8989
	}

	@radarr host radarr.dev.tim-boo.com
	handle @radarr {
		reverse_proxy gluetun:7878
	}

	@lidarr host lidarr.dev.tim-boo.com
	handle @lidarr {
		reverse_proxy gluetun:8686
	}

	@bazarr host bazarr.dev.tim-boo.com
	handle @bazarr {
		reverse_proxy gluetun:6767
	}

	@vault host vaultwarden.dev.tim-boo.com
	handle @vault {
		# Vaultwarden 1.29+ uses single port for all traffic including websockets
		reverse_proxy vaultwarden:80 {
			header_up X-Real-IP {remote_host}
		}
	}

	@ytdlp host ytdlp.dev.tim-boo.com
	handle @ytdlp {
		reverse_proxy yt-dlp-webui:3030
	}

	@librespeed host librespeed.dev.tim-boo.com
	handle @librespeed {
		reverse_proxy librespeed:8080
	}

	@iptracker host iptracker.dev.tim-boo.com
	handle @iptracker {
		reverse_proxy ip-tracker:8000
	}

	@goaccess host goaccess.dev.tim-boo.com
	handle @goaccess {
		# 1. Proxy the WebSocket explicitly first
		handle /ws {
			reverse_proxy goaccess:7890
		}

		# 2. Serve static files for everything else
		handle {
			root * /var/www/goaccess
			file_server
		}
	}

	@filebrowser host filebrowser.dev.tim-boo.com
	handle @filebrowser {
		reverse_proxy filebrowser:80
	}

	# Catch-all
	handle {
		abort
	}
}


*.tim-boo.com {
	log_append client_country {geoip2.country_code}
	log_append client_city {geoip2.city_name}

	log {
		output file /var/log/caddy/wildcard-access.log {
			roll_size 50mb
			roll_keep 5
		}
		# Wrap the standard JSON output and rename the IP field
		format filter {
			wrap json
			fields {
				request>remote_ip rename client_ip
			}
		}
	}

	# 2. Global Security Headers (Applies to both Jellyfin and Seerr)
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Robots-Tag "none, noarchive, nosnippet, notranslate, noimageindex" # Hides you from Search Engines
		-Server # Hides Caddy from scanners
	}

	# 3. Jellyfin
	@jellyfin host jellyfin.tim-boo.com
	handle @jellyfin {
		reverse_proxy jellyfin:8096
	}

	# 4. Overseerr / Jellyseerr
	@seerr host seerr.tim-boo.com
	handle @seerr {
		reverse_proxy seerr:5055
	}

	# 5. Catch-all: Drop unhandled subdomains
	handle {
		abort
	}

}
