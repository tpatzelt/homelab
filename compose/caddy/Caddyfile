{
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	crowdsec {
		api_url http://crowdsec:8080
		api_key {env.CROWDSEC_BOUNCER_API_KEY}
		ticker_interval 15s
	}
	order crowdsec first

	servers {
		trusted_proxies static private_ranges
	}
}

*.dev.{$DOMAIN} {
	@beszel host beszel.dev.{$DOMAIN}
	handle @beszel {
		reverse_proxy beszel:8090
	}

	@dozzle host dozzle.dev.{$DOMAIN}
	handle @dozzle {
		reverse_proxy dozzle:8080
	}

	@pihole host pihole.dev.{$DOMAIN}
	handle @pihole {
		redir / /admin/
		reverse_proxy https://pihole:443 {
			transport http {
				tls_insecure_skip_verify
			}
		}
	}

	@heimdall host heimdall.dev.{$DOMAIN}
	handle @heimdall {
		reverse_proxy heimdall:80
	}

	@immich host immich.dev.{$DOMAIN}
	handle @immich {
		reverse_proxy immich-server:2283
	}

	@karakeep host karakeep.dev.{$DOMAIN}
	handle @karakeep {
		reverse_proxy karakeep:3000
	}

	@jellyfin host jellyfin.dev.{$DOMAIN}
	handle @jellyfin {
		reverse_proxy jellyfin:8096 {
			header_up X-Forwarded-Proto https
		}
	}

	@qb host qbittorrent.dev.{$DOMAIN}
	handle @qb {
		reverse_proxy gluetun:8081
	}

	@prowlarr host prowlarr.dev.{$DOMAIN}
	handle @prowlarr {
		reverse_proxy gluetun:9696
	}

	@seerr host seerr.dev.{$DOMAIN}
	handle @seerr {
		reverse_proxy seerr:5055
	}

	@sonarr host sonarr.dev.{$DOMAIN}
	handle @sonarr {
		reverse_proxy gluetun:8989
	}

	@radarr host radarr.dev.{$DOMAIN}
	handle @radarr {
		reverse_proxy gluetun:7878
	}

	@lidarr host lidarr.dev.{$DOMAIN}
	handle @lidarr {
		reverse_proxy gluetun:8686
	}

	@bazarr host bazarr.dev.{$DOMAIN}
	handle @bazarr {
		reverse_proxy gluetun:6767
	}

	@vault host vaultwarden.dev.{$DOMAIN}
	handle @vault {
		# Vaultwarden 1.29+ uses single port for all traffic including websockets
		reverse_proxy vaultwarden:80 {
			header_up X-Real-IP {remote_host}
		}
	}

	@iptracker host iptracker.dev.{$DOMAIN}
	handle @iptracker {
		reverse_proxy ip-tracker:8000
	}

	@goaccess host goaccess.dev.{$DOMAIN}
	handle @goaccess {
		# 1. Proxy the WebSocket explicitly first
		handle /ws {
			reverse_proxy goaccess:7890
		}

		# 2. Serve static files for everything else
		handle {
			root * /var/www/goaccess
			file_server
		}
	}

	@filebrowser host filebrowser.dev.{$DOMAIN}
	handle @filebrowser {
		reverse_proxy filebrowser:80
	}

	@navidrome host navidrome.dev.{$DOMAIN}
	handle @navidrome {
		reverse_proxy navidrome:4533
	}

	@annabel-rene host annabel-rene.dev.{$DOMAIN}
	handle @annabel-rene {
		reverse_proxy annabel-rene-frontend:4321
	}

	# Catch-all
	handle {
		abort
	}
}

*.{$DOMAIN} {
	route {
		crowdsec
	}

	log {
		output file /var/log/caddy/wildcard-access.log {
			roll_size 50mb
			roll_keep 5
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Robots-Tag "none, noarchive, nosnippet, notranslate, noimageindex" # Hides you from Search Engines
		-Server # Hides Caddy from scanners
	}

	# Reached only via the cloudflared tunnel (no public A record, no forwarded ports)
	@annabel-rene host annabel-rene.{$DOMAIN}
	handle @annabel-rene {
		reverse_proxy annabel-rene-frontend:4321
	}

	# Catch-all: Drop unhandled subdomains
	handle {
		abort
	}
}
